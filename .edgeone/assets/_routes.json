{
  "routes": [
    {
      "path": "/api/*",
      "function": "api",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"]
    },
    {
      "path": "/admin",
      "serve": "admin.html"
    },
    {
      "path": "/admin/*",
      "serve": "admin.html"
    },
    {
      "path": "/assets/*",
      "serve": "."
    },
    {
      "path": "/frontend/*",
      "serve": "."
    },
    {
      "path": "/admin-panel/*",
      "serve": "."
    },
    {
      "path": "/*",
      "serve": "."
    }
  ]
}
