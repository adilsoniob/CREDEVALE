{
  "name": "vale-saude",
  "version": "1.0.0",
  "description": "Vale Saúde - Landing Page + API",
  "pages": {
    "root": ".",
    "include": [
      "index.html",
      "cadastro.html",
      "escolha.html",
      "pagamento.html",
      "ativacao.html",
      "admin.html",
      "styles.css",
      "cadastro.css",
      "escolha.css",
      "script.js",
      "cadastro.js",
      "escolha.js",
      "pagamento.js",
      "ativacao.js",
      "frontend/**",
      "admin-panel/**",
      "assets/**"
    ],
    "exclude": [
      "backend/**",
      "node_modules/**",
      "edge-functions/**",
      "package*.json",
      "iniciar-servidor.bat",
      "log.txt",
      "plan.txt",
      "DOCUMENTACAO.md"
    ],
    "route": {
      "": "index.html",
      "admin/*": "admin.html"
    }
  },
  "functions": {
    "routes": [
      {
        "path": "/api/*",
        "function": "api"
      }
    ]
  },
  "kv": {
    "VALE_SAUDE_KV": {
      "description": "Database KV para Vale Saúde"
    }
  }
}
